{
  "entities": {
    "User": {
      "title": "User",
      "description": "Candidate profile and account information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "bio": { "type": "string" },
        "education": { "type": "string" },
        "experience": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "cvUrl": { "type": "string" },
        "ekycStatus": { "type": "string", "enum": ["none", "pending", "verified", "rejected"] },
        "ekycDocumentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Job": {
      "title": "Job",
      "description": "Job posting details.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "location": { "type": "string" },
        "salary": { "type": "string" },
        "industry": { "type": "string" },
        "description": { "type": "string" },
        "requirements": { "type": "string" },
        "type": { "type": "string", "enum": ["full-time", "part-time", "contract", "remote"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Business": {
      "title": "Business",
      "description": "Company profile information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "description": { "type": "string" },
        "industry": { "type": "string" },
        "website": { "type": "string" }
      }
    },
    "Application": {
      "title": "Application",
      "description": "Job application record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "jobId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "interviewing", "accepted", "rejected"] },
        "appliedAt": { "type": "string", "format": "date-time" }
      }
    },
    "SavedJob": {
      "title": "SavedJob",
      "description": "User's bookmarked jobs.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "jobId": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" }
      }
    },
    "FollowedBusiness": {
      "title": "FollowedBusiness",
      "description": "Businesses followed by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "businessId": { "type": "string" },
        "followedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "Support or feedback messages.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/jobs/{jobId}": { "schema": "Job", "description": "Job listings" },
    "/businesses/{businessId}": { "schema": "Business", "description": "Business profiles" },
    "/applications/{applicationId}": { "schema": "Application", "description": "Job applications" },
    "/savedJobs/{savedJobId}": { "schema": "SavedJob", "description": "User saved jobs" },
    "/followedBusinesses/{followId}": { "schema": "FollowedBusiness", "description": "User followed businesses" },
    "/messages/{messageId}": { "schema": "ContactMessage", "description": "Contact messages" }
  }
}
